generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  profile      PlayerProfile?
}

model PlayerProfile {
  id          String         @id @default(uuid())
  userId      String         @unique
  nickname    String         @unique
  avatarUrl   String?
  level       Int            @default(1)
  experience  Int            @default(0)
  elo         Int            @default(1000)
  country     String?
  gamesPlayed Int            @default(0)
  gamesWon    Int            @default(0)
  gamesLost   Int            @default(0)
  // Soft currency ("Q-coins") players earn by levelling up, finishing
  // daily missions and unlocking achievements. Spending sinks (cosmetic
  // shop, tournament entry) come later — for now this is read-only and
  // surfaces as the chip in the app header.
  coins       Int            @default(0)
  eloHistory  EloHistoryEntry[]
  achievements Achievement[]
  avatarSubmissions AvatarSubmission[] @relation("submitter")
  avatarReviews     AvatarSubmission[] @relation("reviewer")

  // Demographic fields — used as features for behavioural inference / clustering.
  // All optional so registration stays lightweight; populated via /settings.
  // Strictly categorical/numeric — free-text fields were dropped because the
  // simple analytical model can't usefully consume them.
  birthYear         Int?
  gender            String?
  city              String?
  education         String?
  occupation        String?

  // Self-reported psychometric data — high-signal features for clustering
  // game behaviour against player personality.
  mbti              String?       // one of 16 MBTI codes (e.g. "INTJ")
  iqScore           Int?          // self-reported IQ if known
  personalityTraits String[]       @default([])

  // Preferred language for question text. The match server resolves
  // each player's question translation against this column at runtime —
  // mixed-language lobbies are fine, each player just reads their own.
  language          QuestionLanguage @default(en)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  games       PlayerInGame[]
  user        User           @relation(fields: [userId], references: [id])

  friendRequestsSent     Friendship[] @relation("FriendshipRequester")
  friendRequestsReceived Friendship[] @relation("FriendshipAddressee")

  lobbyInvitesSent     LobbyInvite[] @relation("LobbyInviteInviter")
  lobbyInvitesReceived LobbyInvite[] @relation("LobbyInviteInvitee")

  missions PlayerMission[]

  lobbyChatMessages LobbyChatMessage[]
}

// One row per (profile, day, missionCode). `day` is a UTC date string
// (YYYY-MM-DD) so the daily reset rule is timezone-stable. The 3
// missions per day are generated lazily by the API endpoint when the
// player first loads the dashboard that day — no background scheduler
// required. `target` and `reward` are frozen at creation so a catalog
// rebalance doesn't retroactively change yesterday's payouts.
model PlayerMission {
  id          String    @id @default(cuid())
  profileId   String
  missionCode String
  day         String
  target      Int
  reward      Int
  current     Int       @default(0)
  completedAt DateTime?
  // When the coin payout was credited. We auto-claim on completion so
  // claimedAt usually equals completedAt — kept separate so a future
  // "press to claim" flow can split them.
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())

  profile PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, day, missionCode])
  @@index([profileId, day])
}

// Bidirectional friendship — direction is meaningful only while status =
// "pending" (so we know who initiated). Once accepted, both sides
// query symmetric `OR` and treat each other as friends. A single
// (requester, addressee) ordered pair is unique; the application layer
// is responsible for not creating a pair in the opposite direction.
model Friendship {
  id          String    @id @default(cuid())
  requesterId String
  addresseeId String
  // "pending" | "accepted"
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?

  requester PlayerProfile @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee PlayerProfile @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// Direct invite from one profile to another to join a specific lobby.
// The row lives while the invite is "active" — i.e. the invitee hasn't
// joined or dismissed yet. Deletion happens on dismiss, on accept (the
// joinGame path), or transitively when the GameSession/inviter/invitee
// is removed (cascade). The unique(invitee, session) constraint blocks
// duplicate invites from the same lobby — re-inviting is a no-op.
model LobbyInvite {
  id            String   @id @default(cuid())
  inviterId     String
  inviteeId     String
  gameSessionId String
  createdAt     DateTime @default(now())
  // Invites expire after a short window so unanswered invitations
  // don't keep a slot locked indefinitely. The lobby UI filters by
  // expiresAt > now() everywhere — expired rows just sit in the DB
  // until lazy cleanup (re-invite upsert / lobby cascade). The
  // @default(now()) is only there to give pre-existing rows a value
  // during the migration — runtime callers always pass an explicit
  // future timestamp.
  expiresAt     DateTime @default(now())

  inviter     PlayerProfile @relation("LobbyInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee     PlayerProfile @relation("LobbyInviteInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  gameSession GameSession   @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  @@unique([inviteeId, gameSessionId])
  @@index([inviteeId, createdAt])
  @@index([inviterId, gameSessionId])
}

// Per-match record persisted by Colyseus at game_over. Replaces the
// granular live tables (MatchCountry / MatchEvent / MatchQuestion /
// PlayerAnswer / WarAttack / WarAnswer) which are no longer touched
// during gameplay. Both `finalState` and `telemetry` are JSON blobs —
// schemas inferred at analysis time, not enforced here, since the live
// schema may still evolve.
// Avatar moderation queue. A user uploads → row with status="pending",
// file lands in Supabase Storage under `pending/<id>.<ext>`. An admin
// reviews and either approves (file moves to `approved/<profileId>.<ext>`
// and PlayerProfile.avatarUrl is updated) or rejects (file deleted,
// reason recorded). Pre-emptive moderation avoids letting any user-
// uploaded image appear in public UI before a human has looked at it.
model AvatarSubmission {
  id                String   @id @default(cuid())
  profileId         String
  // Path inside the `avatars` Supabase Storage bucket, including any
  // sub-folder. e.g. "pending/abc123.png" or "approved/<uuid>.png".
  storagePath       String
  // Convenience cache of the resolved public URL so the UI doesn't have
  // to call getPublicUrl on every render.
  publicUrl         String
  // "pending" | "approved" | "rejected"
  status            String   @default("pending")
  rejectionReason   String?
  createdAt         DateTime @default(now())
  reviewedAt        DateTime?
  reviewerProfileId String?

  profile  PlayerProfile  @relation("submitter", fields: [profileId], references: [id], onDelete: Cascade)
  reviewer PlayerProfile? @relation("reviewer", fields: [reviewerProfileId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([profileId, createdAt])
}

// One row per (profile, achievement code) — unlocked-only. We never
// store "locked" achievements; the UI derives "locked" from the
// catalogue minus what's in this table. Cascade-on-delete so wiping a
// profile (which would only happen in admin cleanup) takes their
// unlock history with it.
model Achievement {
  id         String   @id @default(cuid())
  profileId  String
  code       String
  unlockedAt DateTime @default(now())

  profile    PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, code])
  @@index([profileId, unlockedAt])
}

// One row per match per player — the ELO they ended a match with and
// how much it moved. Drives the player's rating-over-time chart on the
// profile page. Survives session deletion (sessionId is nullable +
// SetNull on cascade) so the chart doesn't get gappy when an old
// GameSession is purged.
model EloHistoryEntry {
  id        String   @id @default(cuid())
  profileId String
  sessionId String?
  eloAfter  Int
  delta     Int
  isWinner  Boolean  @default(false)
  createdAt DateTime @default(now())

  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  session   GameSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt])
}

model MatchSnapshot {
  id          String      @id @default(cuid())
  sessionId   String      @unique
  winnerId    String?
  duration    Int         // ms from room create to game_over
  finalState  Json
  telemetry   Json
  createdAt   DateTime    @default(now())

  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model GameSession {
  id                String          @id @default(cuid())
  status            String          @default("waiting")
  createdAt         DateTime        @default(now())
  // Max players the host chose at lobby creation (2/3/4). Determines
  // how many seats the lobby UI shows and how the playable-set is
  // resolved when the match starts. Older rows default to 4 — that's
  // what the dashboard "Play now" did before mode selection existed.
  maxPlayers        Int             @default(4)
  // Ranked vs Custom. Ranked locks all settings to their defaults and
  // pays out ELO + W/L stats. Custom lets the host tweak timers and
  // question categories — XP / coins / achievements still credit, but
  // the match doesn't affect ELO or the W/L counters.
  ranked            Boolean         @default(true)
  // Per-phase timer overrides (seconds). Ignored when ranked=true; the
  // Colyseus room substitutes the hard-coded defaults instead. Stored
  // as Ints so cheap to read and validate at lobby start.
  capitalsTimerSec  Int             @default(20)
  expandTimerSec    Int             @default(10)
  warTimerSec       Int             @default(15)
  // Question categories the host enabled. Empty array means "all
  // categories" — saves us having to enumerate defaults at insert
  // time. Ignored when ranked=true (always uses the full pool).
  categories        QuestionCategory[] @default([])
  stage             String          @default("capitals")
  turnIndex         Int             @default(0)
  currentQuestionId String?
  pickOrder         String[]
  picksRemaining    Int             @default(0)
  pickExpiresAt     DateTime?
  nextQuestionAt    DateTime?
  capitalExpiresAt  DateTime?
  warTurnExpiresAt  DateTime?
  snapshot          MatchSnapshot?
  warTurns          Int             @default(0)
  winnerId          String?
  // Colyseus room id, populated by the host's first joinOrCreate. Guests
  // read this and call joinById, so only one client races to create the
  // room — eliminates the "two clients in two different rooms" desync.
  gameRoomId        String?
  matchMap          MatchCountry[]
  questions         MatchQuestion[]
  players           PlayerInGame[]
  currentAttackId   String?
  attacks           WarAttack[]
  events            MatchEvent[]
  eloHistoryEntries EloHistoryEntry[]
  lobbyInvites      LobbyInvite[]
  chatMessages      LobbyChatMessage[]
}

// In-lobby chat. One row per message — never edited or soft-deleted. Cascade
// from GameSession so dropping a disbanded lobby cleans its history.
model LobbyChatMessage {
  id            String      @id @default(cuid())
  gameSessionId String
  authorId      String
  text          String      @db.VarChar(500)
  createdAt     DateTime    @default(now())

  gameSession GameSession   @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  author      PlayerProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([gameSessionId, createdAt])
}

model PlayerInGame {
  id             String         @id @default(cuid())
  gameSessionId  String
  profileId      String
  joinedAt       DateTime       @default(now())
  role           String         @default("player")
  turnOrder      Int?
  ownedCountries MatchCountry[]
  answers        PlayerAnswer[]
  gameSession    GameSession    @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  profile        PlayerProfile  @relation(fields: [profileId], references: [id])

  attacksAsAttacker  WarAttack[] @relation("attacker")
  attacksAsDefender  WarAttack[] @relation("defender")
  warAnswers         WarAnswer[]
  events             MatchEvent[]
  choices            MatchChoice[]

  @@unique([gameSessionId, profileId])
}

// Pre-match strategic choices — one row per (player, choice key).
// Captures the player's selection on a binary card (e.g. capital style) so
// downstream game logic can read it and analytics can correlate it with
// demographics / behaviour.
model MatchChoice {
  id             String       @id @default(cuid())
  playerInGameId String
  key            String
  value          String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  player         PlayerInGame @relation(fields: [playerInGameId], references: [id], onDelete: Cascade)

  @@unique([playerInGameId, key])
}

model CountryTemplate {
  id        Int            @id
  name      String
  neighbors Int[]
  svgId     String
  matches   MatchCountry[]
}

model MatchCountry {
  id            String          @id @default(cuid())
  gameSessionId String
  templateId    Int
  ownerId       String?
  isCapital     Boolean         @default(false)
  armies        Int             @default(1)
  // Max HP this territory can have. Mostly relevant for capitals where the
  // player's pre-match choice (standard / risky) sets a different ceiling.
  // Used by the HP-dot UI to render "current / max" without guessing.
  maxArmies     Int             @default(1)
  points        Int             @default(200)
  gameSession   GameSession     @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  owner         PlayerInGame?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  template      CountryTemplate @relation(fields: [templateId], references: [id])
  attacks   WarAttack[]  

  @@unique([gameSessionId, templateId])
}

enum QuestionCategory {
  geography
  history
  math
  science
  sports
  pop_culture
  language
  general
}

// Question + UI language. PlayerProfile.language picks which translation
// each player sees during a match; questions also carry a language so we
// can group siblings together (a "what is the capital of France" group
// has one row per supported language sharing the same numeric/index answer).
enum QuestionLanguage {
  en
  ru
  uk
  pl
}

model Question {
  id         Int              @id @default(autoincrement())
  // Shared key across all translations of the same conceptual question.
  // Default cuid() lets pre-existing rows survive the migration as
  // singleton groups — they still work, just only resolve for `en`
  // players (other languages fall back to en at render time).
  groupKey   String           @default(dbgenerated("gen_random_uuid()::text"))
  language   QuestionLanguage @default(en)
  text       String
  // The numeric answer is invariant across translations of a group —
  // we duplicate the value on each row so a single read pulls every
  // field needed to score, without joining to a parent table.
  answer     Float
  category   QuestionCategory @default(general)
  matches    MatchQuestion[]
  warAttacks WarAttack[]

  @@unique([groupKey, language])
  @@index([category, language])
}

model MatchQuestion {
  id            String         @id @default(cuid())
  gameSessionId String
  questionId    Int
  isActive      Boolean        @default(true)
  expiresAt     DateTime
  results       Json?
  gameSession   GameSession    @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  question      Question       @relation(fields: [questionId], references: [id])
  answers       PlayerAnswer[]
}

model PlayerAnswer {
  id              String        @id @default(cuid())
  matchQuestionId String
  playerId        String
  answer          Float
  answeredAt      DateTime      @default(now())

  // Behavioural telemetry — ms relative to question start.
  // firstInputAtMs = "thinking time before typing"
  // inputChangeCount = onChange events (proxy for hesitation/corrections)
  firstInputAtMs   Int?
  inputChangeCount Int           @default(0)

  matchQuestion   MatchQuestion @relation(fields: [matchQuestionId], references: [id], onDelete: Cascade)
  player          PlayerInGame  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchQuestionId, playerId])
}

model WarAttack {
  id            String    @id @default(cuid())
  gameSessionId String
  attackerId    String
  defenderId    String
  countryId     String
  isActive      Boolean   @default(true)
  expiresAt     DateTime?

  // Snapshot of who was right on the most recent MC round (overwritten each
  // siege round). Drives the reveal banner on clients.
  lastAttackerCorrect Boolean?
  lastDefenderCorrect Boolean?

  // Tie-breaker (used when both got the multiple-choice question right)
  tieQuestionId      Int?
  tieExpiresAt       DateTime?
  tieAttackerAnswer  Float?
  tieDefenderAnswer  Float?
  // Time spent thinking, in milliseconds since the tie phase started.
  // Used both as a tiebreak (faster wins on equal diffs) and for display.
  tieAttackerTimeMs  Int?
  tieDefenderTimeMs  Int?

  gameSession   GameSession  @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  attacker      PlayerInGame @relation("attacker", fields: [attackerId], references: [id], onDelete: Cascade)
  defender      PlayerInGame @relation("defender", fields: [defenderId], references: [id], onDelete: Cascade)
  country       MatchCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  answers       WarAnswer[]
  questionId    Int?
  question      WarQuestion? @relation(fields: [questionId], references: [id])
  tieQuestion   Question?    @relation(fields: [tieQuestionId], references: [id])
}

model WarAnswer {
  id          String    @id @default(cuid())
  attackId    String
  playerId    String
  isCorrect   Boolean

  // Behavioural telemetry — ms since the MC question started.
  submittedAtMs Int?

  attack      WarAttack    @relation(fields: [attackId], references: [id], onDelete: Cascade)
  player      PlayerInGame @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([attackId, playerId])
}

model WarQuestion {
  id           Int              @id @default(autoincrement())
  // Shared across all translations of the same MC question.
  groupKey     String           @default(dbgenerated("gen_random_uuid()::text"))
  language     QuestionLanguage @default(en)
  text         String
  options      String[]
  // Position (0-based) of the correct option inside `options`. Same
  // value across every translation of a group — translators must keep
  // option order consistent.
  correctIndex Int
  category     QuestionCategory @default(general)
  attacks      WarAttack[]

  @@unique([groupKey, language])
  @@index([category, language])
}

model MatchEvent {
  id            String        @id @default(cuid())
  gameSessionId String
  createdAt     DateTime      @default(now())
  type          String
  actorId       String?
  payload       Json

  gameSession   GameSession   @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  actor         PlayerInGame? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([gameSessionId, createdAt])
}