// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  profile      PlayerProfile?
}

model PlayerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  nickname    String   @unique
  avatarUrl   String?

  level       Int      @default(1)
  experience  Int      @default(0)
  elo         Int      @default(1000)

  country     String?

  gamesPlayed Int      @default(0)
  gamesWon    Int      @default(0)
  gamesLost   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  games       PlayerInGame[]
  
}

model GameSession {
  id        String   @id @default(cuid())
  status    String   @default("waiting")

  stage     String   @default("capitals")
  turnIndex Int      @default(0)

  createdAt DateTime @default(now())

  players   PlayerInGame[]
  matchMap  MatchCountry[]
}

model PlayerInGame {
  id            String @id @default(cuid())
  gameSessionId String
  profileId     String

  role          String @default("player")
  joinedAt      DateTime @default(now())
  turnOrder     Int?

  gameSession   GameSession @relation(fields: [gameSessionId], references: [id])
  profile       PlayerProfile @relation(fields: [profileId], references: [id])
  ownedCountries MatchCountry[]

  @@unique([gameSessionId, profileId])
}

model CountryTemplate {
  id        Int     @id
  name      String
  neighbors Int[]   
  matches    MatchCountry[] 
}


model MatchCountry {
  id            String @id @default(cuid())
  gameSessionId String
  templateId    Int
  ownerId       String?
  isCapital     Boolean @default(false)
  armies        Int     @default(1)

  gameSession   GameSession   @relation(fields: [gameSessionId], references: [id])
  template      CountryTemplate @relation(fields: [templateId], references: [id])
  owner         PlayerInGame?   @relation(fields: [ownerId], references: [id])

  @@unique([gameSessionId, templateId])
}